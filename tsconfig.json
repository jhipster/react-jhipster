{
  "include": ["src"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "commonjs",
    "target": "ES2020",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "lib": ["ES2020", "dom"],
    "types": ["webpack-env"],
    "rootDir": "./src",
    "outDir": "./lib",
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules", "bundles", "coverage", "build", "**/*.spec.ts", "**/*.spec.tsx"]
}
