{
  "name": "react-jhipster",
  "version": "1.0.0",
  "description": "A Jhipster util library for React",
  "keywords": [
    "jhipster",
    "react"
  ],
  "homepage": "https://www.jhipster.tech",
  "bugs": {
    "url": "https://github.com/jhipster/generator-jhipster/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jhipster/react-jhipster.git"
  },
  "license": "Apache-2.0",
  "author": "Deepu KS",
  "exports": "./lib/index.js",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "typings": "lib/index.d.ts",
  "files": [
    "src",
    "lib",
    "LICENCE.txt",
    "NOTICE",
    "README.md",
    "index.ts",
    "react-jhipster.ts"
  ],
  "scripts": {
    "build": "npm run cleanup && npm run tsc",
    "cleanup": "rimraf --glob lib src/*.d.ts src/**/*.d.ts src/*.{js,jsx} src/**/*.{js,jsx} tests/**/*.d.ts tests/*.d.ts",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "npm run build && husky",
    "prettier:check": "prettier --check \"*.ts\" package.json \"{src,test}/**/*.{ts,tsx}\"",
    "prettier:format": "prettier --write \"*.ts\" package.json \"{src,test}/**/*.{ts,tsx}\"",
    "release": "npm test && git push && git push --tags && npm publish",
    "release:major": "npm run build && npm run commit-lib && npm version major -a -m \"Update to %s\" && npm run release",
    "release:minor": "npm run build && npm run commit-lib && npm version minor -a -m \"Update to %s\" && npm run release",
    "release:patch": "npm run build && npm run commit-lib && npm version patch -a -m \"Update to %s\" && npm run release",
    "pretest": "npm run lint && npm run prettier:check",
    "test": "npm run vitest",
    "test:watch": "npm run vitest",
    "tsc": "tsc",
    "vitest": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "npm run lint:fix"
    ]
  },
  "dependencies": {
    "lodash": "^4.17.23",
    "numeral": "^2.0.6",
    "sanitize-html": "^2.17.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/numeral": "^2.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "axios": "^1.13.6",
    "dayjs": "^1.11.19",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "rimraf": "^6.1.3",
    "typescript": "6.0.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "axios": "*",
    "dayjs": "^1.11.0",
    "react": "^18 || ^19",
    "react-bootstrap": "^2.10.0",
    "react-dom": "^18 || ^19",
    "react-hook-form": "^7.54.0"
  },
  "peerDependenciesMeta": {
    "react-bootstrap": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
